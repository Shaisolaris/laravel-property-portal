{
    "compilerOptions": {
        "target": "es2016",
        "module": "commonjs",
        "esModuleInterop": true,
        "forceConsistentCasingInFileNames": true,
        "strict": true,
        "skipLibCheck": true,
        "paths": {
            "~/*": ["resources/js/*", "./node_modules/*/dist/*", ""],
            "@assets/*": ["resources/assets/*"]
        }
    }
}
