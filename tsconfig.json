{
    "compilerOptions": {
        "target": "es2016",
        "module": "commonjs",
        "esModuleInterop": true,
        "forceConsistentCasingInFileNames": true,
        "strict": true,
        "skipLibCheck": true,
        "paths": {
            "~/*": ["./resources/js/*", "./dist/*"],
            "@assets/*": ["./resources/assets/*"]
        },
        "include": [
            "components.d.ts",
            "resources/ts/BootstrapVue.ts",
            "resources/ts/SelfComponents.ts",
        ]
    }
}
